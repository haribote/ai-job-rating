# npm supply-chain hardening (npm 11+)
# Block dependency lifecycle scripts (postinstall etc.) — the top npm attack vector.
# If a build legitimately needs a script, allowlist it explicitly instead of disabling this.
ignore-scripts=true

# Pin exact versions on install (no ^/~ ranges) for reproducible, tamper-evident installs.
save-exact=true

# Only install package versions published at least N days ago (cooldown against
# compromised fresh releases). Unit is days. Cannot be combined with `before`.
min-release-age=7

# Enforce the package.json "engines" field.
engine-strict=true

# Cosmetic: hide funding output.
fund=false
