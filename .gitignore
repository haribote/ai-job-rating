# Dependencies（末尾スラッシュ無し: worktree の node_modules は symlink のため
# ディレクトリ限定の `node_modules/` では無視されない）
node_modules

# Secrets — never commit (templates like .dev.vars.example are tracked)
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*
!.env.example

# Cloudflare / Wrangler
.wrangler/
.wrangler-e2e/
dist/

# Playwright（E2E 生成物・撮影 PNG は PII を含み得るためコミットしない）
/playwright-report/
/test-results/
/screenshots/
/blob-report/
/playwright/.cache/

# Build output
build/
*.tsbuildinfo

# Vite SPA ビルド成果物（#96 / #97）。public/ は Workers の assets ディレクトリでもある。
# スタイルは Tailwind が globals.css をバンドルして assets/ へ出力するため、public/ の中身は
# すべて生成物（index.html / assets/* / .vite）であり追跡しない。
/public/index.html
/public/assets/
/public/.vite/

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store

# Issue #15 spike — 投入した実求人 HTML（PII 含む）はコミットしない
/spike/

# superpowers ブレインストーミングのモックアップ（ローカル作業用）
.superpowers/
