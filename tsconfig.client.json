{
	// クライアント（React SPA）専用の型検査設定。
	// なぜ分けるか: Worker ランタイム（root tsconfig, DOM 無し）と DOM/JSX が必要なクライアントは
	// グローバル型（fetch/Response 等）が衝突し得るため、lib と jsx を分離して検査する。
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": [],
		// shadcn 規約のパスエイリアス（vite.config.ts の resolve.alias と一致）。
		// moduleResolution: Bundler では baseUrl 無しで tsconfig からの相対 paths が解決される。
		"paths": {
			"@/*": ["./src/client/*"]
		}
	},
	// root の exclude（src/client）を打ち消し、クライアントのみを対象にする。
	"include": ["src/client"],
	"exclude": []
}
