{
	"name": "ai-job-rating",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "npm run build && wrangler dev",
		"dev:client": "vite",
		"build": "vite build",
		"deploy": "npm run build && wrangler deploy",
		"test": "vitest run",
		"test:watch": "vitest",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:screenshots": "playwright test --grep @screenshot",
		"smoke": "node scripts/live-smoke.mjs",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.client.json",
		"lint": "biome check .",
		"format": "biome format --write .",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@cloudflare/puppeteer": "1.1.0",
		"@radix-ui/react-dialog": "1.1.17",
		"@radix-ui/react-slot": "1.3.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"hono": "4.12.26",
		"lucide-react": "1.21.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"recharts": "3.8.1",
		"tailwind-merge": "3.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@cloudflare/vitest-pool-workers": "0.16.18",
		"@playwright/test": "1.61.0",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"autoprefixer": "10.5.0",
		"jsdom": "29.1.1",
		"postcss": "8.5.15",
		"tailwindcss": "3.4.19",
		"tailwindcss-animate": "1.0.7",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.9",
		"wrangler": "4.103.0"
	},
	"overrides": {
		"ws": "8.21.0"
	}
}
