{
	"name": "ai-job-rating",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "wrangler dev",
		"dev:client": "vite",
		"build": "npm run build:css && vite build",
		"deploy": "npm run build && wrangler deploy",
		"build:css": "node --import ./scripts/register-ts-hook.mjs scripts/build-css.mjs",
		"build:css:check": "node --import ./scripts/register-ts-hook.mjs scripts/build-css.mjs --check",
		"test": "vitest run",
		"test:watch": "vitest",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:screenshots": "playwright test --grep @screenshot",
		"typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.client.json",
		"lint": "biome check .",
		"format": "biome format --write .",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@cloudflare/puppeteer": "1.1.0",
		"hono": "4.12.25",
		"react": "19.2.7",
		"react-dom": "19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@cloudflare/vitest-pool-workers": "0.16.15",
		"@playwright/test": "1.61.0",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.8",
		"wrangler": "4.100.0"
	},
	"overrides": {
		"ws": "8.21.0"
	}
}
